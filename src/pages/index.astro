---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import MenuCard from '../components/MenuCard.astro';
---

<Layout>
  <!-- Hero -->
  <Hero />

  <!-- Concept -->
  <section id="concept" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="section-title">Concept</p>
        <h2 class="section-heading">こだわり</h2>
        <div class="divider mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="border border-border fade-in overflow-hidden">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="/images/gallery/03.jpg" alt="鮮度抜群の鶏刺身" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="text-center p-8">
            <h3 class="font-serif text-lg tracking-[0.1em] mb-4">鮮度抜群の刺身</h3>
            <p class="text-sm text-text-muted leading-relaxed">
              鶏刺身・魚刺身をはじめ、鮮度にこだわった素材を毎日仕入れ。旨い肴をご提供します。
            </p>
          </div>
        </div>

        <div class="border border-border fade-in overflow-hidden">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="/images/gallery/07.jpg" alt="豊富なお酒" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="text-center p-8">
            <h3 class="font-serif text-lg tracking-[0.1em] mb-4">豊富なお酒</h3>
            <p class="text-sm text-text-muted leading-relaxed">
              日本酒、焼酎、ワイン、カクテルなど、料理に合うお酒を豊富にご用意。飲み放題コースも。
            </p>
          </div>
        </div>

        <div class="border border-border fade-in overflow-hidden">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="/images/gallery/09.jpg" alt="深夜3時まで営業" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="text-center p-8">
            <h3 class="font-serif text-lg tracking-[0.1em] mb-4">深夜3時まで営業</h3>
            <p class="text-sm text-text-muted leading-relaxed">
              仕事帰りや二次会にも。新大宮で深夜まで楽しめる居酒屋です。貸切もご相談ください。
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: 飲み放題 -->
  <section class="py-24 px-6 bg-bg-light">
    <div class="max-w-5xl mx-auto fade-in">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/gallery/08.jpg" alt="飲み放題コース" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="text-center md:text-left">
          <p class="section-title">All You Can Drink</p>
          <h2 class="section-heading mb-6">飲み放題コース</h2>
          <div class="divider md:mx-0 mx-auto"></div>
          <p class="text-sm text-text-muted leading-relaxed mt-8">
            生ビール、日本酒、焼酎、ワイン、カクテル、サワーなど豊富なラインナップ。<br />
            宴会・歓送迎会・女子会など各種ご宴会にご利用ください。
          </p>
          <div class="mt-6">
            <a href="/menu" class="btn-outline">
              コース詳細を見る →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Preview -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="section-title">Menu</p>
        <h2 class="section-heading">おすすめ料理</h2>
        <div class="divider mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 fade-in">
        <MenuCard
          name="一縁旨味コース"
          price="¥3,500（税込）"
          description="10品 / 4～16名様"
          tag="おすすめ"
          image="/images/gallery/02.jpg"
        />
        <MenuCard
          name="お気軽コース"
          price="¥2,500（税込）"
          description="8品 / 4～16名様"
          image="/images/gallery/04.jpg"
        />
        <MenuCard
          name="飲み放題付き♡女子会コース"
          price="¥4,500（税込）"
          description="9品 / 4～16名様"
          tag="飲み放題"
          image="/images/gallery/05.jpg"
        />
        <MenuCard
          name="がいなどりコース"
          price="¥4,500（税込）"
          description="9品 / 4～16名様"
          image="/images/gallery/11.jpg"
        />
      </div>

      <div class="text-center mt-12 fade-in">
        <a href="/menu" class="btn-outline">
          メニューをすべて見る →
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="py-24 px-6 bg-bg-light">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="section-title">Gallery</p>
        <h2 class="section-heading">ギャラリー</h2>
        <div class="divider mx-auto"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 fade-in">
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/01.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/02.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/06.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/10.jpg" alt="店内" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/13.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/11.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="section-title">Information</p>
        <h2 class="section-heading">店舗情報</h2>
        <div class="divider mx-auto"></div>
      </div>

      <div class="border border-border fade-in">
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] border-b border-border">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">住所</div>
          <div class="px-6 py-4 text-sm text-text-muted">
            奈良県奈良市三条添川町3-1
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] border-b border-border">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">電話番号</div>
          <div class="px-6 py-4 text-sm text-text-muted">
            <a href="tel:0742-35-5535" class="hover:text-accent transition-colors">0742-35-5535</a>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] border-b border-border">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">営業時間</div>
          <div class="px-6 py-4 text-sm text-text-muted">
            <p>17:00〜翌3:00（L.O. 2:30）</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] border-b border-border">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">定休日</div>
          <div class="px-6 py-4 text-sm text-text-muted">不定休</div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] border-b border-border">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">席数</div>
          <div class="px-6 py-4 text-sm text-text-muted">
            22席（カウンター席・テーブル席）
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] border-b border-border">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">喫煙</div>
          <div class="px-6 py-4 text-sm text-text-muted">全席禁煙</div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr]">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">お支払い</div>
          <div class="px-6 py-4 text-sm text-text-muted">
            VISA / Master / JCB / AMEX<br />
            PayPay / d払い / 楽天ペイ / au PAY
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12 fade-in">
        <a href="tel:0742-35-5535" class="btn-primary justify-center">
          電話で予約
        </a>
        <a href="/access" class="btn-outline justify-center">
          アクセスを見る
        </a>
      </div>
    </div>
  </section>
</Layout>
