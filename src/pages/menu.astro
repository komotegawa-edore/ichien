---
import Layout from '../layouts/Layout.astro';
import MenuCard from '../components/MenuCard.astro';
---

<Layout title="メニュー | 呑み処 一縁 -ICHIEN-">
  <!-- Page Header -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <p class="section-title">Menu</p>
      <h1 class="section-heading">メニュー</h1>
      <div class="divider mx-auto"></div>
    </div>
  </section>

  <!-- コース -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 fade-in">
        <h2 class="font-serif text-xl tracking-[0.15em] mb-2">コース</h2>
        <p class="text-sm text-text-muted">ご宴会・歓送迎会・二次会にご利用ください</p>
        <div class="divider"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 fade-in">
        <MenuCard
          name="一縁旨味コース"
          price="¥3,500（税込）"
          description="10品 / 4～16名様"
          tag="おすすめ"
          image="/images/gallery/02.jpg"
        />
        <MenuCard
          name="お気軽コース"
          price="¥2,500（税込）"
          description="8品 / 4～16名様"
          image="/images/gallery/04.jpg"
        />
        <MenuCard
          name="飲み放題付き♡女子会コース"
          price="¥4,500（税込）"
          description="9品 / 4～16名様"
          tag="飲み放題"
          image="/images/gallery/05.jpg"
        />
        <MenuCard
          name="がいなどりコース"
          price="¥4,500（税込）"
          description="9品 / 4～16名様"
          image="/images/gallery/11.jpg"
        />
      </div>

      <p class="text-xs text-text-muted mt-6 fade-in">
        ※ コース内容は季節や仕入れにより変更になる場合がございます<br />
        ※ 貸切のご相談も承っております（最大22名様）<br />
        ※ お祝い・サプライズ等、お気軽にご相談ください
      </p>
    </div>
  </section>

  <!-- ギャラリー -->
  <section class="py-16 px-6 bg-bg-light">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 fade-in">
        <h2 class="font-serif text-xl tracking-[0.15em] mb-2">料理の写真</h2>
        <div class="divider"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 fade-in">
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/01.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/03.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/06.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/07.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/08.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/09.jpg" alt="店内" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/10.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/12.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/gallery/13.jpg" alt="料理" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto text-center fade-in">
      <p class="text-sm text-text-muted mb-6">ご予約・お問い合わせはお電話にて</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0742-35-5535" class="btn-primary justify-center">
          電話で予約する
        </a>
        <a
          href="https://www.instagram.com/nomidokoro_ichien/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline justify-center"
        >
          Instagramを見る
        </a>
      </div>
    </div>
  </section>
</Layout>
